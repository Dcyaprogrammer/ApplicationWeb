---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
---

<Layout title="Design Process | HCI Portfolio">
    <PageHeader 
        title="Design Process" 
        subtitle="From wireframes to high-fidelity designs."
    />

    <Section title="User Flow">
        <div class="w-full aspect-[21/9] bg-neutral-800 border border-neutral-700 flex items-center justify-center mb-8">
            <span class="font-mono text-neutral-500">USER_FLOW_DIAGRAM.png</span>
        </div>
        <p class="text-neutral-400 max-w-3xl">
            We mapped out the primary user journey, focusing on the onboarding experience and the core gamification loop.
        </p>
    </Section>

    <Section title="Wireframes" class="bg-neutral-900/20 border-t border-b border-neutral-800">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
             {/* Placeholders for wireframes */}
            {[1, 2, 3, 4].map((i) => (
                <div class="aspect-[9/16] bg-neutral-800 border border-neutral-700 flex items-center justify-center hover:border-white transition-colors">
                    <span class="font-mono text-xs text-neutral-500">SCREEN_{i}</span>
                </div>
            ))}
        </div>
    </Section>
</Layout>
