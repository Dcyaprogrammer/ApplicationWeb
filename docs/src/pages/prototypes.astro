---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
---

<Layout title="Prototypes | HCI Portfolio">
    <PageHeader 
        title="Prototypes" 
        subtitle="Interactive demonstrations of the application."
    />

    <Section title="Interactive Prototype">
        <div class="w-full aspect-video bg-neutral-900 border border-neutral-800 flex flex-col items-center justify-center relative overflow-hidden group">
             <div class="absolute inset-0 bg-grid-pattern opacity-10"></div>
            <span class="font-mono text-neutral-500 mb-4">FIGMA_EMBED_OR_VIDEO</span>
            <button class="btn btn-primary">Launch Prototype</button>
        </div>
    </Section>

    <Section title="Key Features" class="bg-neutral-900/20 border-t border-b border-neutral-800">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <div>
                <h3 class="text-2xl font-bold mb-4">Gamified Dashboard</h3>
                <p class="text-neutral-400 mb-4">
                    Students can track their progress through levels, earning badges and rewards for completing tasks.
                </p>
                <div class="aspect-video bg-neutral-800 border border-neutral-700"></div>
            </div>
            <div>
                <h3 class="text-2xl font-bold mb-4">Interactive Map</h3>
                <p class="text-neutral-400 mb-4">
                    A visual exploration tool for discovering universities and cultural information.
                </p>
                <div class="aspect-video bg-neutral-800 border border-neutral-700"></div>
            </div>
        </div>
    </Section>
</Layout>
