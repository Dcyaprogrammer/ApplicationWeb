---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
---

<Layout title="Testing | HCI Portfolio">
    <PageHeader 
        title="User Testing" 
        subtitle="Validating our design decisions with real users."
    />

    <Section title="Methodology">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="p-6 border border-neutral-800 bg-neutral-900/30">
                <h3 class="font-bold text-xl mb-2">Think Aloud Protocol</h3>
                <p class="text-neutral-400">Users were asked to verbalize their thoughts while performing specific tasks.</p>
            </div>
            <div class="p-6 border border-neutral-800 bg-neutral-900/30">
                <h3 class="font-bold text-xl mb-2">Heuristic Evaluation</h3>
                <p class="text-neutral-400">Experts reviewed the interface against Nielsen's 10 Usability Heuristics.</p>
            </div>
        </div>
    </Section>

    <Section title="Key Findings" class="border-t border-neutral-800">
        <ul class="space-y-4">
            <li class="flex items-start">
                <span class="text-green-500 mr-4 font-mono">✓</span>
                <p class="text-neutral-300">Navigation structure was clear and intuitive for 90% of users.</p>
            </li>
            <li class="flex items-start">
                <span class="text-yellow-500 mr-4 font-mono">!</span>
                <p class="text-neutral-300">Some users struggled with the gamification terminology.</p>
            </li>
            <li class="flex items-start">
                <span class="text-green-500 mr-4 font-mono">✓</span>
                <p class="text-neutral-300">Visual design was rated highly for engagement.</p>
            </li>
        </ul>
    </Section>
</Layout>
