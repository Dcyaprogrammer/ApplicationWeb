---
interface Props {
    title: string;
    subtitle: string;
    tag?: string;
    primaryAction?: { text: string; href: string };
    secondaryAction?: { text: string; href: string };
}

const { title, subtitle, tag, primaryAction, secondaryAction } = Astro.props;
---

<section class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden border-b border-border-dark bg-bg-dark">
    <!-- Base Grid Pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-40 pointer-events-none"></div>
    
    <!-- Technical Geometric Decorations -->
    <div class="absolute inset-0 pointer-events-none select-none overflow-hidden">
        <!-- Large circle outline - partially visible on the right -->
        <svg class="absolute -right-20 top-0 h-[600px] w-[600px] text-border-dark opacity-50 animate-pulse-slow" viewBox="0 0 100 100" fill="none">
            <circle cx="50" cy="50" r="49" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 4" />
            <circle cx="50" cy="50" r="35" stroke="currentColor" stroke-width="0.2" />
        </svg>

        <!-- Vertical Line on the left -->
        <div class="absolute left-10 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-border-dark to-transparent opacity-80 hidden md:block"></div>
        
        <!-- Random Plus Signs (Crosshairs) -->
        <div class="absolute top-32 left-10 text-neutral-500 font-mono text-xs opacity-70 hidden md:block">+</div>
        <div class="absolute bottom-20 right-10 text-neutral-500 font-mono text-xs opacity-70">+</div>
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 text-border-dark font-mono text-6xl opacity-20 font-thin">+</div>
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10 flex flex-col justify-center min-h-[50vh]">
        {tag && (
            <div class="inline-block self-start border border-border-dark bg-bg-darker/50 backdrop-blur px-3 py-1 mb-6 text-xs font-mono text-neutral-400 tracking-wider uppercase">
                {tag}
            </div>
        )}
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter mb-6 leading-tight text-white font-display">
            {title}
        </h1>
        <p class="text-xl md:text-2xl text-neutral-400 max-w-3xl leading-relaxed mb-10 font-light">
            {subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
            {primaryAction && (
                <a href={primaryAction.href} class="btn btn-primary text-lg px-8 py-4">
                    {primaryAction.text}
                </a>
            )}
            {secondaryAction && (
                <a href={secondaryAction.href} class="btn btn-secondary text-lg px-8 py-4">
                    {secondaryAction.text}
                </a>
            )}
        </div>
    </div>
</section>
