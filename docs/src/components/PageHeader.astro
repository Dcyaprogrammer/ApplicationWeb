---
interface Props {
    title: string;
    subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<div class="relative pt-32 pb-16 border-b border-border-dark bg-bg-darker overflow-hidden">
    <!-- Background Decorations -->
    <div class="absolute inset-0 bg-grid-pattern opacity-30 pointer-events-none"></div>
    <div class="absolute top-0 right-0 p-4 opacity-50">
        <svg width="100" height="100" viewBox="0 0 100 100" fill="none" class="text-border-dark animate-spin-slow">
            <path d="M50 0V100M0 50H100" stroke="currentColor" stroke-width="0.5" />
            <circle cx="50" cy="50" r="30" stroke="currentColor" stroke-width="0.5" stroke-dasharray="4 4" />
        </svg>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="inline-block border-b-2 border-brand-accent pb-2 mb-6">
            <span class="font-mono text-brand-accent text-sm tracking-widest uppercase">SECTION // {title.toUpperCase()}</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter mb-4 text-white font-display">
            {title}
        </h1>
        <p class="text-xl text-neutral-400 max-w-3xl leading-relaxed font-light border-l-2 border-border-dark pl-6">
            {subtitle}
        </p>
    </div>
</div>
